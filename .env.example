PORT=8080

NUVEMSHOP_APP_ID=
NUVEMSHOP_CLIENT_SECRET=
NUVEMSHOP_APP_URL=https://your-public-domain.com
NUVEMSHOP_WEBHOOK_BASE_URL=https://your-public-domain.com

# Billing Nuvemshop (Partner Portal)
# concept_code da loja — normalmente vem do webhook subscription/updated.
# Use como fallback se o webhook ainda nao tiver sido recebido.
NUVEMSHOP_BILLING_CONCEPT_CODE=
# auto = tenta Nuvemshop e cai para Supabase se concept_code ausente
# nuvemshop = exige billing nativo (falha sem concept_code)
# self = billing proprio do parceiro (padrao para apps Gratis + vendas no app)
OMAFIT_BILLING_MODE=self
# Taxa USD→BRL para precos dos planos (padrao: 5.7)
USD_TO_BRL_RATE=5.7

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

OMAFIT_WIDGET_URL=https://your-public-domain.com/widget.html
OMAFIT_SUPPORT_URL=https://your-public-domain.com/app.html?section=dashboard
OMAFIT_SUPPORT_EMAIL=contato@omafit.co
OMAFIT_APP_NAME=Omafit
# Lojas Patagonia em homolog sem theme na query do SDK (IDs separados por virgula)
OMAFIT_STOREFRONT_SDK_STORE_IDS=

OMAFIT_WIDGET_HMAC_SECRET=
WIDGET_CATALOG_HMAC_SECRET=

# Try On Marketing (WhatsApp) — mesmo valor no Supabase Edge secrets
# Mesmo valor no Supabase (Edge Functions secrets) e no Railway/Netlify.
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OMAFIT_WHATSAPP_PROXY_SECRET=
# Piloto: omitir = Arrascaneta Shopify + Nuvemshop 6994912; * = Growth+ em todas
# OMAFIT_WHATSAPP_PILOT_STORE_KEYS=nuvemshop/6994912

# Stripe (billing Nuvemshop — apenas server-side)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs (USD, alinhados à landing omafit-widget — gere com npm run stripe:catalog)
STRIPE_PRICE_ONDEMAND=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
# Legado — aceitos como fallback
STRIPE_PRICE_ONDEMAND_BRL=
STRIPE_PRICE_GROWTH_BRL=
STRIPE_PRICE_PRO_BRL=
STRIPE_PRICE_ENTERPRISE_BRL=

VITE_OMAFIT_APP_URL=https://your-public-domain.com
VITE_OMAFIT_WIDGET_HMAC_SECRET=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
