PORT=8080

NUVEMSHOP_APP_ID=
NUVEMSHOP_CLIENT_SECRET=
NUVEMSHOP_APP_URL=https://your-public-domain.com
NUVEMSHOP_WEBHOOK_BASE_URL=https://your-public-domain.com

# Billing Nuvemshop (Partner Portal)
# concept_code da loja — normalmente vem do webhook subscription/updated.
# Use como fallback se o webhook ainda nao tiver sido recebido.
NUVEMSHOP_BILLING_CONCEPT_CODE=
# auto = tenta Nuvemshop e cai para Supabase se concept_code ausente
# nuvemshop = exige billing nativo (falha sem concept_code)
# self = apenas Supabase, sem cobranca na Nuvemshop
OMAFIT_BILLING_MODE=auto
# Taxa USD→BRL para precos dos planos (padrao: 5.7)
USD_TO_BRL_RATE=5.7

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

OMAFIT_WIDGET_URL=https://your-public-domain.com/widget.html
OMAFIT_SUPPORT_URL=https://your-public-domain.com/app.html?section=dashboard
OMAFIT_SUPPORT_EMAIL=contato@omafit.co
OMAFIT_APP_NAME=Omafit

OMAFIT_WIDGET_HMAC_SECRET=
WIDGET_CATALOG_HMAC_SECRET=
VITE_OMAFIT_APP_URL=https://your-public-domain.com
VITE_OMAFIT_WIDGET_HMAC_SECRET=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
